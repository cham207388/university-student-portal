DYNAMODB_INSTRUCTORS_TABLE=student-portal-instructors
DYNAMODB_COURSES_TABLE=student-portal-courses
DYNAMODB_ENROLLMENTS_TABLE=student-portal-enrollments
STUDENT_PORTAL_SEED_ENABLED=false
